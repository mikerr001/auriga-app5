<?xml version="1.0" encoding="utf-8"?>
<!--
    Auriga dragon-eye launcher icon foreground.
    A stylised coiled serpent with a gold eye — the watcher.
    NOTE: VectorDrawable only supports <path>, <group>, <clip-path>.
    Ellipses and circles are encoded as path arcs.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer coil — gold serpent body -->
    <path
        android:pathData="M54,18 C34,18 18,34 18,54 C18,74 34,90 54,90 C74,90 90,74 90,54 C90,44 86,35 79,28"
        android:strokeColor="#C9A84C"
        android:strokeWidth="5"
        android:fillColor="#00000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Inner coil — crimson inner body -->
    <path
        android:pathData="M54,28 C40,28 28,40 28,54 C28,68 40,80 54,80"
        android:strokeColor="#8B1A1A"
        android:strokeWidth="4"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!--
        Dragon eye — gold filled circle (path arc: two semicircles = full circle)
        Circle at (54,54) r=8: M46,54 A8,8 0 1 0 62,54 A8,8 0 1 0 46,54 Z
    -->
    <path
        android:pathData="M46,54 A8,8 0 1,0 62,54 A8,8 0 1,0 46,54 Z"
        android:fillColor="#C9A84C" />

    <!-- Slit pupil — dark vertical oval: (54,54) rx=3 ry=5 -->
    <path
        android:pathData="M51,54 A3,5 0 1,0 57,54 A3,5 0 1,0 51,54 Z"
        android:fillColor="#06080C" />

    <!-- Eye highlight — small circle at (56,51) r=1.5 -->
    <path
        android:pathData="M54.5,51 A1.5,1.5 0 1,0 57.5,51 A1.5,1.5 0 1,0 54.5,51 Z"
        android:fillColor="#E8C56A" />

    <!-- Serpent head curving toward top right -->
    <path
        android:pathData="M76,30 C80,26 84,24 86,22"
        android:strokeColor="#C9A84C"
        android:strokeWidth="5"
        android:fillColor="#00000000"
        android:strokeLineCap="round" />

    <!-- Forked tongue — crimson -->
    <path
        android:pathData="M86,22 L90,18 M86,22 L90,24"
        android:strokeColor="#CC2020"
        android:strokeWidth="2"
        android:strokeLineCap="round" />

    <!-- Scale marks along outer coil -->
    <path
        android:pathData="M72,22 L74,19 M82,32 L85,30 M88,44 L91,44 M87,57 L90,58"
        android:strokeColor="#C9A84C"
        android:strokeWidth="2"
        android:strokeLineCap="round" />

</vector>
