<?xml version="1.0" encoding="utf-8"?>
<!--
    Auriga — Chinese Serpent Dragon UI
    Ink-black void, dragon-gold accents, crimson danger signalling.
    The dragon watches. Silent until there is something to say.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/auriga_background">

    <!-- Full-screen camera feed — the dragon's sight -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Top status panel — dark gradient so text stays legible over camera -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_status_overlay"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Brand header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/dragonMark"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_dragon_mark"
                android:contentDescription="Auriga dragon mark" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/app_name"
                android:textColor="@color/auriga_accent_bright"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.20"
                android:fontFamily="sans-serif-condensed" />

            <!-- Subtle live indicator -->
            <TextView
                android:id="@+id/liveIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textColor="#99CC2020"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Gold separator line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#44C9A84C" />

        <!-- Status text — the dragon speaks here -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_starting"
            android:textColor="@color/auriga_text_primary"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.35"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>

    <!-- Bottom panel — rises from black, holds the talk button -->
    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_panel"
        android:gravity="center_horizontal"
        android:paddingTop="28dp"
        android:paddingBottom="40dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tagline above button -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/tagline"
            android:textColor="@color/auriga_text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.18"
            android:fontFamily="sans-serif-condensed" />

        <!-- Talk button — dragon's voice trigger -->
        <Button
            android:id="@+id/talkButton"
            style="@style/Widget.Auriga.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_ask_auriga"
            android:textSize="15sp"
            android:letterSpacing="0.14"
            android:contentDescription="@string/btn_ask_auriga_desc"
            android:background="@drawable/bg_talk_button"
            android:textColor="@color/auriga_accent_bright"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
